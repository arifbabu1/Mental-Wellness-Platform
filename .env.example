SECRET_KEY=change-this-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SITE_DOMAIN=localhost:8000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# PythonAnywhere production example:
# DEBUG=False
# ALLOWED_HOSTS=yourusername.pythonanywhere.com
# CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com
# SITE_DOMAIN=yourusername.pythonanywhere.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# Google OAuth. Keep the secret out of source control.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_ID=1
ACCOUNT_EMAIL_VERIFICATION=optional

# TESTING MODE: Payment gateway verification is bypassed for this university demo.
# Keep True on PythonAnywhere unless you intentionally build and audit a real gateway.
PAYMENT_TEST_MODE=True
PAYMENT_TEST_OTP=123456
SUPPORT_EMAIL=support@mentalwellness.local
ADMIN_NOTIFICATION_EMAIL=admin@mentalwellness.local

# Email fallback. You can also manage SMTP from the custom admin Email Config page.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@mentalwellness.local

# Local development can omit DATABASE_URL and use SQLite.
# For free PostgreSQL hosting, use Neon/Supabase connection string:
# DATABASE_URL=postgresql://user:password@host:5432/database

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_TIMEOUT=30
OLLAMA_EMBED_TIMEOUT=5
