SECRET_KEY=replace-this-with-your-own-long-random-production-secret-key-64-plus-chars
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com,http://127.0.0.1:8000,http://localhost:8000
SITE_DOMAIN=yourusername.pythonanywhere.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# Google OAuth. Keep the secret out of source control.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_ID=1
ACCOUNT_EMAIL_VERIFICATION=optional

# TESTING MODE: Payment gateway verification is bypassed for this university demo.
# Keep True on PythonAnywhere unless you intentionally build and audit a real gateway.
PAYMENT_TEST_MODE=True
PAYMENT_TEST_OTP=123456
SUPPORT_EMAIL=support@mentalwellness.local
ADMIN_NOTIFICATION_EMAIL=admin@mentalwellness.local

# Email fallback. You can also manage SMTP from the custom admin Email Config page.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@mentalwellness.local

# PythonAnywhere free plan can use SQLite by omitting DATABASE_URL.
# Optional external PostgreSQL requires installing a PostgreSQL driver too.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Optional hybrid chatbot AI. Emergency detection always stays local.
CHATBOT_AI_ENABLED=True
CHATBOT_AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
CHATBOT_TIMEOUT=6
CHATBOT_MAX_MESSAGE_LENGTH=1000
CHATBOT_AUTO_SYNC_KNOWLEDGE=False
